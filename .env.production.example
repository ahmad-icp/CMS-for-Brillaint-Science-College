ENVIRONMENT=production
PROJECT_NAME=College ERP Platform
API_VERSION=1.0.0
API_PREFIX=/api/v1

POSTGRES_DB=cep
POSTGRES_USER=cep_app
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql+psycopg://cep_app:replace-with-a-long-random-password@postgres:5432/cep

REDIS_PASSWORD=replace-with-a-different-long-random-password
REDIS_URL=redis://:replace-with-a-different-long-random-password@redis:6379/0

JWT_SECRET_KEY=replace-with-at-least-64-random-characters
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_DEV_AUTH_HEADERS=false

CORS_ORIGINS=https://erp.example.edu.pk
TRUSTED_HOSTS=erp.example.edu.pk
READINESS_TIMEOUT_SECONDS=2
DB_CONNECT_TIMEOUT_SECONDS=10
DB_STATEMENT_TIMEOUT_SECONDS=60
MIGRATION_LOCK_TIMEOUT_SECONDS=30

HTTP_PORT=80
BACKUP_RETENTION_DAYS=30
BACKUP_INTERVAL_SECONDS=86400
