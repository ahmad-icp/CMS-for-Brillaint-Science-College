# Local Docker host ports. Change these when Windows reports a port conflict.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Local service credentials. Keep production values in .env.production only.
POSTGRES_DB=cep_local
POSTGRES_USER=cep_local
POSTGRES_PASSWORD=cep_local_password
DATABASE_URL=postgresql+psycopg://cep_local:cep_local_password@postgres:5432/cep_local
REDIS_URL=redis://redis:6379/0

CORS_ORIGINS=http://localhost:8080,http://localhost:8081,http://localhost:5173
TRUSTED_HOSTS=localhost,127.0.0.1,backend
